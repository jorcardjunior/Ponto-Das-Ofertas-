# ============================================
# Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git!
# ============================================

# Database (Neon PostgreSQL)
# Use the pooler connection string for better performance:
# postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-32-char-secret-here-minimum"

# xAI Grok API Key (optional - for AI features)
XAI_API_KEY=""

# Node environment
NODE_ENV=production

# Skip env validation during build
SKIP_ENV_VALIDATION=1
