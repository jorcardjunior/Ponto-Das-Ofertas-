# Database
# PostgreSQL (produção)
DATABASE_URL="postgresql://user:password@localhost:5432/estoque?schema=public"
# SQLite (desenvolvimento local)
# DATABASE_URL="file:./dev.db"

# Auth
# Gere um secret seguro: openssl rand -base64 32
AUTH_SECRET="troque-por-uma-string-aleatoria-de-32-chars-min"

# Invite code for registration (leave empty to disable)
REGISTER_INVITE_CODE="ponto2026"
NEXT_PUBLIC_INVITE_REQUIRED="1"

# xAI Grok API Key
# Crie sua chave em: https://console.x.ai
XAI_API_KEY="sua-chave-aqui"

# Server
PORT=3001
HOSTNAME=0.0.0.0

# Env validation (set to "1" to skip, e.g. in build)
SKIP_ENV_VALIDATION=
